# 1. Alles ignorieren
*

# 2. Spezifische Dateien und Ordner der Extension erlauben
!manifest.json
!background.js
!content.js
!popup.html
!popup.js
!popup.css
!translations.js
!README.md
!README.de.md
!.gitignore

# 3. Ordner erlauben
# detect/: nur Runtime-Dateien versionieren, Tests bleiben lokal (wie *.test.js sonst auch)
!detect/
!detect/classify.js
!detect/gtm-detect.js
!detect/gtm-relay.js
!images/
!images/*
!screenshots/
!screenshots/*
!webstore/
!webstore/*
!scripts/
!scripts/*

# 4. Git-Konfiguration selbst erlauben (falls nötig)
!.gitkeep
